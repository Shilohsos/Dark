// Signal Generation
supertrend(_src, factor, atrLen) =>
    atr = ta.atr(atrLen)
    upperBand = _src + factor * atr
    lowerBand = _src - factor * atr
    prevLowerBand = nz(lowerBand[1])
    prevUpperBand = nz(upperBand[1])
    lowerBand := lowerBand > prevLowerBand or close[1] < prevLowerBand ? lowerBand : prevLowerBand
    upperBand := upperBand < prevUpperBand or close[1] > prevUpperBand ? upperBand : prevUpperBand
    int direction = na
    float superTrend = na
    prevSuperTrend = superTrend[1]
    if na(atr[1])
        direction := 1
    else if prevSuperTrend == prevUpperBand
        direction := close > upperBand ? -1 : 1
    else
        direction := close < lowerBand ? 1 : -1
    superTrend := direction == -1 ? lowerBand : upperBand
    [superTrend, direction] 
    
// SMA 
ocAvg       = math.avg(open, close)
sma4        = ta.sma(close, 8)
sma5        = ta.sma(close, 9)
sma9        = ta.sma(close, 13)
psar        = ta.sar(0.02, 0.02, 0.2)
//*in Easy Words Super Trend + SMA = Signals
[supertrend, direction] = supertrend(close, sensitivity, 11)
source = close, period = 150
// Colors
green       = #2BBC4D, green2   = #00DD00
red         = #C51D0B, red2     = #DD0000
//barcolor(close > supertrend ? #2BE300 : red2)
// Candle Colouring By SpyDank
//TradingView standard RSI calculation
src = close
len = input.int(14, minval=1, title='RSI Length')
up = ta.rma(math.max(ta.change(src), 0), len)
down = ta.rma(-math.min(ta.change(src), 0), len)
rsi = down == 0 ? 100 : up == 0 ? 0 : 100 - 100 / (1 + up / down)
// High Lows
y1 = low - (ta.atr(30) * 2), y1B = low - ta.atr(30)
y2 = high + (ta.atr(30) * 2), y2B = high + ta.atr(30)
bull = ta.crossover(close, supertrend) and close >= sma9
bear = ta.crossunder(close, supertrend) and close <= sma9

rvol    = volume / ta.sma(volume, volLen)
volPass = not useVolFilter or rvol > rvolThresh

// Gate entries
bull_ok = bull and volPass
bear_ok = bear and volPass

// Plots
// ---------------------------- Fast ---------------------------- \\
candle  = ta.sma(close, 21)
reach   = ta.sma(close, 34)
buys  =  bull_ok ? label.new(bar_index, y1, sma4 >= sma5 ? "BUY" : "BUY", xloc.bar_index, yloc.price, #00CC00, label.style_label_up, #141923, size.normal) : na
sells =  bear_ok ? label.new(bar_index, y2, sma4 <= sma5 ? "SELL" : "SELL", xloc.bar_index, yloc.price, #CC0000, label.style_label_down, color.white, size.normal) : na
plotshape(bull_ok, title="Buy Signal", style=shape.labelup, location=location.belowbar,
     color=color.green, text="BUY", size=size.normal)
plotshape(bear_ok, title="Sell Signal", style=shape.labeldown, location=location.abovebar,
     color=color.red, text="SELL", size=size.normal)
trigger2 = bull_ok ? 1 : 0
countBull = ta.barssince(bull_ok)
countBear = ta.barssince(bear_ok)
trigger   = nz(countBull, bar_index) < nz(countBear, bar_index) ? 1 : 0
lastTrade(src) => ta.valuewhen(bull_ok or bear_ok , src, 0)
alertcondition(bull_ok, title='Buy Signal', message = "BUY")
alertcondition(bear_ok, title='Buy Signal', message = "SELL") 
