// --- MACD Settings (Hardcoded) ---
msrc = close
fastLength = 12
slowLength = 26
signalLength = 9
// --- MACD Function ---
getMACD(msrc) =>
    fastMA = ta.ema(msrc, fastLength)
    slowMA = ta.ema(msrc, slowLength)
    macd = fastMA - slowMA
    signal = ta.sma(macd, signalLength)
    [macd, signal]
// --- Request MACD Data from 15min and 360min ---
[macd15, signal15] = request.security(syminfo.tickerid, "15",  getMACD(msrc))
[macd360, signal360] = request.security(syminfo.tickerid, "360", getMACD(msrc))
// --- Determine Bias for each timeframe ---
isBuy15   = macd15 >= signal15
biasText15 = isBuy15 ? "Look For Sell Only" : "Look For Buy Only"
biasColor15 = isBuy15 ? textColorSell : textColorBuy
isBuy360   = macd360 >= signal360
biasText360 = isBuy360 ? "Look For Sell Only" : "Look For Buy Only"
biasColor360 = isBuy360 ? textColorSell : textColorBuy
// --- Overall Bias (Example: Follow 360M) ---
overallText = biasText360
overallColor = biasColor360
// --- Dashboard Table (4 rows: Title + Overall + 15M + 360M) ---
var table Mdash = table.new(position.bottom_center, 1, 4)
if barstate.islast and showDashboard
    // Row 0 - Title
    table.cell(Mdash, 0, 0, "Institutional MACD Bias", text_color=titleColor, text_size=size.small, bgcolor=titleBgColor)
   
    // Row 2 - 15M Bias
    table.cell(Mdash, 0, 1, "Short Term: " + biasText15, text_color=biasColor15, text_size=size.small, bgcolor=bgColor)
    // Row 3 - 360M Bias
    table.cell(Mdash, 0, 2, "Long Term: " + biasText360, text_color=biasColor360, text_size=size.small, bgcolor=bgColor)
     // Row 1 - Overall Bias
    table.cell(Mdash, 0, 3, "Overall Bias: " + overallText, text_color=overallColor, text_size=size.small, bgcolor=bgColor)
else if barstate.islast and not showDashboard
    table.clear(Mdash, 0, 0)
