//@version=5
indicator("Pine Scalper v1", overlay=true)

fastLength = input.int(50, title="Fast SMA Length")
slowLength = input.int(200, title="Slow SMA Length")

fastSma = ta.sma(close, fastLength)
slowSma = ta.sma(close, slowLength)

plot(fastSma, title="Fast SMA", color=color.new(color.teal, 0), linewidth=2)
plot(slowSma, title="Slow SMA", color=color.new(color.orange, 0), linewidth=2)

longCondition = ta.crossover(fastSma, slowSma)
shortCondition = ta.crossunder(fastSma, slowSma)

slPercent = input.float(1.0, title="Stop Loss (%)", step=0.1, minval=0.0)
tp1Percent = input.float(1.5, title="Take Profit 1 (%)", step=0.1, minval=0.0)
tp2Percent = input.float(3.0, title="Take Profit 2 (%)", step=0.1, minval=0.0)

var float activeLongEntry = na
var float activeShortEntry = na

if longCondition
    activeLongEntry := close
    activeShortEntry := na
if shortCondition
    activeShortEntry := close
    activeLongEntry := na

float longStop = na
float longTp1 = na
float longTp2 = na
if not na(activeLongEntry)
    longStop := activeLongEntry * (1 - slPercent * 0.01)
    longTp1 := activeLongEntry * (1 + tp1Percent * 0.01)
    longTp2 := activeLongEntry * (1 + tp2Percent * 0.01)

float shortStop = na
float shortTp1 = na
float shortTp2 = na
if not na(activeShortEntry)
    shortStop := activeShortEntry * (1 + slPercent * 0.01)
    shortTp1 := activeShortEntry * (1 - tp1Percent * 0.01)
    shortTp2 := activeShortEntry * (1 - tp2Percent * 0.01)

plotshape(longCondition, title="Buy Signal", location=location.belowbar, color=color.new(color.green, 0), style=shape.labelup, text="Buy")
plotshape(shortCondition, title="Sell Signal", location=location.abovebar, color=color.new(color.red, 0), style=shape.labeldown, text="Sell")

var label longDetailLabel = na
var label shortDetailLabel = na

if longCondition and not na(longStop)
    if not na(longDetailLabel)
        label.delete(longDetailLabel)
    longLabelText = "Buy\nSL: " + str.tostring(longStop, format.mintick) + "\nTP1: " + str.tostring(longTp1, format.mintick) + "\nTP2: " + str.tostring(longTp2, format.mintick)
    longDetailLabel := label.new(bar_index, low, longLabelText, style=label.style_label_up, color=color.new(color.green, 0), textcolor=color.white)
    if not na(shortDetailLabel)
        label.delete(shortDetailLabel)
        shortDetailLabel := na

if shortCondition and not na(shortStop)
    if not na(shortDetailLabel)
        label.delete(shortDetailLabel)
    shortLabelText = "Sell\nSL: " + str.tostring(shortStop, format.mintick) + "\nTP1: " + str.tostring(shortTp1, format.mintick) + "\nTP2: " + str.tostring(shortTp2, format.mintick)
    shortDetailLabel := label.new(bar_index, high, shortLabelText, style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white)
    if not na(longDetailLabel)
        label.delete(longDetailLabel)
        longDetailLabel := na

plot(longStop, title="Long Stop Loss", color=color.new(color.red, 40), linewidth=1, style=plot.style_linebr)
plot(longTp1, title="Long Take Profit 1", color=color.new(color.green, 40), linewidth=1, style=plot.style_linebr)
plot(longTp2, title="Long Take Profit 2", color=color.new(color.green, 0), linewidth=1, style=plot.style_linebr)

plot(shortStop, title="Short Stop Loss", color=color.new(color.red, 40), linewidth=1, style=plot.style_linebr)
plot(shortTp1, title="Short Take Profit 1", color=color.new(color.teal, 40), linewidth=1, style=plot.style_linebr)
plot(shortTp2, title="Short Take Profit 2", color=color.new(color.teal, 0), linewidth=1, style=plot.style_linebr)

alertcondition(longCondition, title="Fast SMA Crosses Above Slow SMA", message="Buy Signal: Fast SMA crossed above Slow SMA")
alertcondition(shortCondition, title="Fast SMA Crosses Below Slow SMA", message="Sell Signal: Fast SMA crossed below Slow SMA")
